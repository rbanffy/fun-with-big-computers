 00008          01  WS-NUM               PIC 999 VALUE 2.
 00009          01  WS-DIVISOR           PIC 999.
 00010          01  WS-IS-PRIME          PIC 9 VALUE 1.
 00011          01  WS-QUOTIENT          PIC 999.
 00012          01  WS-REMAINDER         PIC 999.
 00013          01  WS-LIMIT             PIC 999 VALUE 50.
 00014
 00015          PROCEDURE DIVISION.
 00016          MAIN-PARA.
 00017              GO TO MAIN-LOOP.
 00018
 00019          MAIN-LOOP.
 00020              IF WS-NUM > WS-LIMIT
 00021                  GO TO END-PROG.
 00022              MOVE 1 TO WS-IS-PRIME.
 00023              MOVE 2 TO WS-DIVISOR.
 00024              GO TO DIV-CHECK.
 00025
 00026          DIV-CHECK.
 00027              IF WS-DIVISOR * WS-DIVISOR > WS-NUM
 00028                  GO TO PRIME-CHECK.
 00029
 00030          DIV-LOOP.
 00031              DIVIDE WS-NUM BY WS-DIVISOR
 00032                  GIVING WS-QUOTIENT
 00033                  REMAINDER WS-REMAINDER.
 00034              IF WS-REMAINDER = 0
 00035                  MOVE 0 TO WS-IS-PRIME.
 00036              ADD 1 TO WS-DIVISOR.
 00037              GO TO DIV-CHECK.
 00038
 00039          PRIME-CHECK.
 00040              IF WS-IS-PRIME = 1
 00041                  DISPLAY WS-NUM.
 00042              ADD 1 TO WS-NUM.
 00043              GO TO MAIN-LOOP.
 00044
 00045          END-PROG.
 00046              STOP RUN.
